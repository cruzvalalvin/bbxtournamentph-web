{
  "name": "bbxtournamentph-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@bbxtournamentph/web",
    "dev:web": "npm run dev --workspace=@bbxtournamentph/web",
    "dev:api": "npm run dev --workspace=@bbxtournamentph/api",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=@bbxtournamentph/web",
    "build:api": "npm run build --workspace=@bbxtournamentph/api",
    "start": "npm run start --workspace=@bbxtournamentph/web",
    "start:web": "npm run start --workspace=@bbxtournamentph/web",
    "start:api": "npm run start --workspace=@bbxtournamentph/api",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
